# ── Backend ─────────────────────────────────────────────────────
# ── Database ───────────────────────────────────────────────────
DATABASE_URL=             # Supabase Postgres connection string (postgresql://postgres.<project-ref>:password@aws-0-<region>.pooler.supabase.com:6543/postgres?sslmode=require)

# ── Supabase Auth ───────────────────────────────────────────────
SUPABASE_URL=             # Supabase project URL for backend auth verification
SUPABASE_ANON_KEY=        # Supabase anon/publishable key for backend auth verification
VITE_SUPABASE_URL=        # Supabase project URL exposed to browser
VITE_SUPABASE_ANON_KEY=   # Supabase anon/publishable key exposed to browser

# ── Admin Role ──────────────────────────────────────────────────
OWNER_UNION_ID=           # Union ID of the app creator; this user gets role "admin" on first login
